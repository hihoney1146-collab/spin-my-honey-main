{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.onlinespinwheel.fun" }],
      "destination": "https://onlinespinwheel.fun/:path*",
      "permanent": true
    },
    { "source": "/terms", "destination": "/terms-and-conditions", "permanent": true },
    { "source": "/about", "destination": "/about-us", "permanent": true },
    { "source": "/contact", "destination": "/contact-us", "permanent": true },
    { "source": "/privacy", "destination": "/privacy-policy", "permanent": true },

    { "source": "/exercise-spin-wheel", "destination": "/exercise-picker-wheel", "permanent": true },
    { "source": "/date-night-idea-wheel", "destination": "/date-night-wheel", "permanent": true },
    { "source": "/what-movie-should-i-watch-wheel", "destination": "/movie-picker-wheel", "permanent": true },
    { "source": "/giveaway-winner-picker-wheel", "destination": "/winner-picker-wheel", "permanent": true },
    { "source": "/zodiac-sign-wheel-game", "destination": "/zodiac-sign-wheel", "permanent": true },
    { "source": "/zodiac-wheel-dates", "destination": "/zodiac-sign-wheel", "permanent": true },
    { "source": "/zodiac-wheel-planets", "destination": "/zodiac-sign-wheel", "permanent": true },
    { "source": "/wheel-of-fortune-zodiac", "destination": "/daily-horoscope-wheel", "permanent": true },
    { "source": "/egyptian-zodiac-wheel", "destination": "/zodiac-sign-wheel", "permanent": true }
  ],
  "rewrites": [
    { "source": "/ads.txt", "destination": "/api/ads" },
    { "source": "/logo.png", "destination": "/logo.png" },
    { "source": "/og-image.png", "destination": "/og-image.png" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(sitemap|pages-sitemap|blog-sitemap|wheels-sitemap|images-sitemap)\\.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    },
    {
      "source": "/blog-featured/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800"
        }
      ]
    },
    {
      "source": "/ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/embed/:slug*",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "upgrade-insecure-requests; frame-ancestors *"
        }
      ]
    },
    {
      "source": "/embed",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "upgrade-insecure-requests; frame-ancestors *"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "upgrade-insecure-requests; default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://pagead2.googlesyndication.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://api.web3forms.com https://www.googletagmanager.com; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com; frame-ancestors 'self'"
        }
      ]
    }
  ]
}
