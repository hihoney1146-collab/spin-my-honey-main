{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.onlinespinwheel.fun" }],
      "destination": "https://onlinespinwheel.fun/:path*",
      "permanent": true
    },
    { "source": "/terms", "destination": "/terms-and-conditions", "permanent": true },
    { "source": "/about", "destination": "/about-us", "permanent": true },
    { "source": "/contact", "destination": "/contact-us", "permanent": true },
    { "source": "/privacy", "destination": "/privacy-policy", "permanent": true },

    { "source": "/author/armghana-zeeshan", "destination": "/team/ceo", "permanent": true },
    { "source": "/author/zoha-zeeshan", "destination": "/team/co-founder", "permanent": true },
    { "source": "/author/raja-jahangir", "destination": "/team/content", "permanent": true },
    { "source": "/author/abdal-khalid", "destination": "/team/social", "permanent": true },

    { "source": "/exercise-spin-wheel", "destination": "/exercise-picker-wheel", "permanent": true },
    { "source": "/date-night-idea-wheel", "destination": "/date-night-wheel", "permanent": true },
    { "source": "/what-movie-should-i-watch-wheel", "destination": "/movie-picker-wheel", "permanent": true },
    { "source": "/giveaway-winner-picker-wheel", "destination": "/winner-picker-wheel", "permanent": true },
    { "source": "/zodiac-sign-wheel-game", "destination": "/zodiac-sign-wheel", "permanent": true },
    { "source": "/zodiac-wheel-dates", "destination": "/zodiac-sign-wheel", "permanent": true },
    { "source": "/zodiac-wheel-planets", "destination": "/zodiac-sign-wheel", "permanent": true },
    { "source": "/wheel-of-fortune-zodiac", "destination": "/daily-horoscope-wheel", "permanent": true },
    { "source": "/egyptian-zodiac-wheel", "destination": "/zodiac-sign-wheel", "permanent": true }
  ],
  "rewrites": [
    { "source": "/ads.txt", "destination": "/api/ads" },
    { "source": "/robots.txt", "destination": "/api/robots" },
    { "source": "/llms.txt", "destination": "/api/llms" },
    { "source": "/sitemap", "destination": "/api/sitemap" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/sitemap.txt", "destination": "/api/sitemap?format=txt" },
    {
      "source": "/((?!api/|(?:sitemap|pages-sitemap|wheels-sitemap|blog-sitemap|images-sitemap)(?:\\.xml)?$|.*\\.(?:xml|txt|png|jpe?g|webp|svg|gif|ico|pdf|csv|json|js|css|map|woff2?)$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(sitemap|sitemap\\.xml|pages-sitemap|pages-sitemap\\.xml|blog-sitemap|blog-sitemap\\.xml|wheels-sitemap|wheels-sitemap\\.xml|images-sitemap|images-sitemap\\.xml|sitemap-index\\.xml)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/sitemap.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    },
    {
      "source": "/blog-featured/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800"
        }
      ]
    },
    {
      "source": "/ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/embed/:slug*",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), gyroscope=(), accelerometer=(), magnetometer=(), payment=(), usb=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "upgrade-insecure-requests; frame-ancestors *"
        }
      ]
    },
    {
      "source": "/embed",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), gyroscope=(), accelerometer=(), magnetometer=(), payment=(), usb=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "upgrade-insecure-requests; frame-ancestors *"
        }
      ]
    },
    {
      "source": "/((?!api(?:/|$)|embed(?:/|$)|ads\\.txt$|robots\\.txt$|llms\\.txt$|sitemap(?:\\.xml|\\.txt)?$|.*sitemap(?:\\.xml)?$).*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), gyroscope=(), accelerometer=(), magnetometer=(), payment=(), usb=()"
        },
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "upgrade-insecure-requests; default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://pagead2.googlesyndication.com https://www.googletagservices.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://api.web3forms.com https://www.googletagmanager.com https://pagead2.googlesyndication.com; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://pagead2.googlesyndication.com; frame-ancestors 'self'"
        }
      ]
    }
  ]
}
